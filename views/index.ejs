<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>LinkKinetic | Professional URL Shortening</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#d0bcff",
                        "primary-container": "#4f378b",
                        "on-primary": "#381e72",
                        "secondary": "#4cd7f6",
                        "secondary-container": "#004e5c",
                        "on-secondary": "#003640",
                        "tertiary": "#4edea3",
                        "surface": "#121214",
                        "surface-container": "#1c1b1f",
                        "surface-container-high": "#2b2930",
                        "outline": "#938f99",
                        "outline-variant": "#49454f",
                        "on-surface": "#e6e1e5",
                        "on-surface-variant": "#cac4d0",
                        "background": "#121214"
                    },
                    fontFamily: {
                        "sans": ["Inter", "sans-serif"],
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "3xl": "1.5rem", "full": "9999px"},
                },
            },
        }
    </script>
<link rel="stylesheet" href="style.css">
</head>
<body class="kinetic-bg min-h-screen flex flex-col relative"><canvas class="fixed inset-0 w-full h-full -z-10 pointer-events-none" id="grid-canvas"></canvas>
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121214]/80 backdrop-blur-md border-b border-white/5">
<nav class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary" data-icon="link">link</span>
<span class="text-lg font-bold tracking-tight text-on-surface">LinkKinetic</span>
</div>
<div class="hidden md:flex gap-8 items-center">
<a class="text-primary text-sm font-medium" href="#">Home</a>
<a class="text-on-surface-variant text-sm font-medium hover:text-on-surface transition-colors" href="#">Analytics</a>
<a class="text-on-surface-variant text-sm font-medium hover:text-on-surface transition-colors" href="#">Developer</a>
</div>
<div class="flex items-center">
<span class="bg-primary/10 text-primary text-[10px] font-bold px-2 py-0.5 rounded border border-primary/20 uppercase tracking-widest">Beta</span>
</div>
</nav>
</header>
<main class="flex-grow pt-32 pb-20 px-6">
<div class="max-w-md mx-auto flex flex-col items-center">
<!-- Professional Logo Section -->
<div class="relative mb-10">
<div class="w-20 h-20 rounded-2xl bg-surface-container-high pro-border flex items-center justify-center">
<span class="material-symbols-outlined text-primary text-4xl" data-icon="bolt" style="font-variation-settings: 'FILL' 1;">bolt</span>
</div>
<div class="absolute -top-1 -right-4 bg-secondary-container px-3 py-1 rounded-sm shadow-md ribbon-angle border border-white/5">
<span class="text-[9px] font-bold tracking-widest text-secondary uppercase">Kinetic</span>
</div>
</div>
<!-- Header Text -->
<div class="text-center mb-10">
<h1 class="text-3xl font-bold tracking-tight text-on-surface mb-3">
                    Precision Shortening
                </h1>

</div>
<!-- Shortener Form -->
<div class="w-full max-w-lg bg-surface-container rounded-2xl p-8 pro-border"><form action="/shorten" class="space-y-4" method="POST" id="long-url-form">
<div class="space-y-1.5">
<label class="text-[11px] font-medium uppercase tracking-wider text-outline ml-1">Destination URL</label>
<div class="relative group">
<input class="w-full bg-surface-container-high border-none rounded-xl py-3.5 pl-11 pr-4 text-on-surface placeholder:text-outline/50 focus:ring-1 focus:ring-primary transition-all text-sm" name="url" placeholder="https://your-long-url.com/..." type="url" id="long-url">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline/60 group-focus-within:text-primary transition-colors text-xl" data-icon="language">language</span>
</div>
</div>
<button class="w-full bg-primary py-3.5 rounded-xl font-semibold text-on-primary hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-sm" type="submit">
<span>Shorten Link</span>
<span class="material-symbols-outlined text-base" data-icon="arrow_forward">arrow_forward</span>
</button>
</form>
</div>
<!-- Result Section -->
<div class="mt-6 w-full">
<div class="bg-surface-container-high/50 rounded-xl p-4 pro-border flex items-center justify-between transition-colors duration-500 ease-in-out" id="alias-container">
<div class="flex flex-col">
<span class="text-on-surface font-mono text-[16px] tracking-tight" id="short-code">kntc.io/px-9921</span>
</div>
<button class="text-outline hover:text-primary transition-colors p-2 rounded-lg bg-surface-container">
<span class="material-symbols-outlined text-lg" data-icon="content_copy">content_copy</span>
</button>
</div>
</div>
<!-- Feature Grid -->

</main>
<!-- Footer -->
<footer class="w-full py-6 border-t border-white/5 bg-[#0e0e10]">
<div class="flex flex-col md:flex-row justify-between items-center px-8 space-y-6 md:space-y-0 max-w-7xl mx-auto">
<div class="flex flex-col md:flex-row items-center gap-4">
<span class="text-on-surface font-semibold text-sm">LinkKinetic</span>
</div>
<div class="flex gap-6 items-center">
<a class="text-outline hover:text-on-surface transition-colors text-xs font-medium" href="#">Documentation</a>
<a href="https://github.com/Ysweb3/ULR-Shortener" class="text-outline hover:text-on-surface transition-colors text-xs font-medium flex items-center gap-2">
  <span class="material-symbols-outlined" data-icon="code">code</span>
  <span>GitHub</span>
</a>
</div>
</div>
</footer>
<script>

</script>
<div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[60] opacity-0 translate-y-4 pointer-events-none transition-all duration-500 ease-in-out" id="toast-notification">
<div class="bg-surface-container-high pro-border rounded-xl p-4 shadow-2xl flex flex-col gap-3 min-w-[300px]">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-tertiary" data-icon="check_circle">check_circle</span>
<span class="text-sm font-medium text-on-surface">Link Generated successfully</span>
</div>
<div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
<div class="h-full bg-primary w-full transition-all duration-[3000ms] linear" id="toast-progress"></div>
</div>
</div>
</div>
<script src="script.js" defer></script>
</body>
</html>